aws_region                   = "us-east-1"
project_name                 = "shopeasy"
artifacts_bucket_name        = "shopeasy-artifacts-267423569109-us-east-1"

# Replace with your Jenkins OIDC issuer after Jenkins is provisioned (Step 3+).
jenkins_oidc_provider_url    = "https://jenkins.example.com/oidc"

# Restrict subjects per repo in production, e.g. "repo:shopeasy/product-service:ref:refs/heads/main"
jenkins_allowed_subjects     = ["repo:shopeasy/*:*"]

ecr_image_tag_mutability     = "IMMUTABLE"
ecr_keep_last_tagged_images  = 30
log_retention_days           = 30
secrets_recovery_window_days = 30
